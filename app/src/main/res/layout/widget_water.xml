<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingTop="4dp"
    android:paddingEnd="10dp"
    android:paddingBottom="4dp">

    <ImageView
        android:id="@+id/widget_cup"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:alpha="0.88"
        android:contentDescription="@string/widget_name"
        android:src="@drawable/ic_widget_cup" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:gravity="bottom"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="今天喝水目标"
            android:textColor="#EFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_amount"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="0/2000ml"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginTop="2dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_add_button"
        android:layout_width="92dp"
        android:layout_height="42dp"
        android:background="@drawable/widget_button_bg"
        android:ellipsize="end"
        android:fontFamily="sans"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="+500ml"
        android:textColor="#FFFFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />
</LinearLayout>
